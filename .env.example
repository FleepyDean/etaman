# Django Settings
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_ALLOWED_HOSTS=your-render-service.onrender.com

# Database (PostgreSQL for production, optional if using SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/etaman

# CORS Settings (add your frontend URL)
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-vercel-app.vercel.app

# Frontend API Base URL
VITE_API_BASE_URL=https://your-render-service.onrender.com
